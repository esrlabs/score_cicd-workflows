{
  // Use Renovate's recommended baseline (PR limits, grouping, etc.)
  // ":disableDependencyDashboard" must be listed after "config:recommended" so it wins
  // during preset expansion. A bare `dependencyDashboard: false` is not enough because
  // Renovate expands presets from resolvedRepoConfig on top of the global config, which
  // causes config:recommended's ":dependencyDashboard" to overwrite the explicit override.
  // See: https://github.com/renovatebot/renovate/pull/43686
  extends: ["config:recommended", ":disableDependencyDashboard"],

  // Commit author
  gitAuthor: "eclipse-score-bot <score-bot@eclipse.org>",

  // Target following repositories
  repositories: [
    "eclipse-score/baselibs",
    "eclipse-score/bazel_cpp_toolchains",
    "eclipse-score/communication",
    "eclipse-score/config_management",
    "eclipse-score/devcontainer",
    "eclipse-score/docs-as-code",
    "eclipse-score/inc_someip_gateway",
    "eclipse-score/infrastructure",
    "eclipse-score/itf",
    "eclipse-score/lifecycle",
    "eclipse-score/logging",
    "eclipse-score/module_template",
    "eclipse-score/os_images",
    "eclipse-score/process_description",
    "eclipse-score/qnx_unit_tests",
    "eclipse-score/persistency",
    "eclipse-score/reference_integration",
    "eclipse-score/rules_imagefs",
    "eclipse-score/scrample",
    "eclipse-score/score",
    "eclipse-score/score-crates",
    "eclipse-score/score_cpp_policies",
    "eclipse-score/testing_tools",
    "eclipse-score/toolchains_gcc",
    "eclipse-score/toolchains_rust",
    "eclipse-score/time",
  ],

  prFooter: "This PR was generated by [#infrastructure](https://github.com/orgs/eclipse-score/discussions/107) automation. Contact us if you have any questions or feedback.",
  prBodyTemplate: "{{{header}}}{{{table}}}{{{warnings}}}{{{notes}}}{{{changelogs}}}{{{controls}}}{{{footer}}}",

  // Add labels to all PRs, so we can actually find them
  labels: [
    "automation",
    "renovate",
  ],

  // Run on all repos, without requiring local renovate.json
  onboarding: false,
  requireConfig: "optional",

  // Kept for clarity; the actual suppression happens via :disableDependencyDashboard above.
  dependencyDashboard: false,

  // Limit PRs to 10 at a time, to avoid overwhelming maintainers
  prConcurrentLimit: 10,

  // Override default weekly schedule from config:recommended so Renovate
  // runs every time the workflow triggers.
  schedule: ["at any time"],

  // ---- BAZEL -----
  
  // For now, only update Bazel module dependencies
  enabledManagers: ["bazel-module"],

  // Allow bazel lockfile updates via `bazel mod deps --lockfile_mode=update`
  allowedUnsafeExecutions: ["bazelModDeps"],

  // Update score packages only
  packageRules: [
    {
      // By default bazel is enabled, but it shall update only score packages,
      // so disable all bazel module updates first.
      matchManagers: ["bazel-module"],
      enabled: false
    },
    {
      // And then re-enable only modules whose package name starts with "score_"
      matchManagers: ["bazel-module"],
      matchPackageNames: ["/^score_/"],
      enabled: true,
    },
    {
      // score_tooling >1.1.0 up to and including 1.2.0 is broken with no fix
      // available. Block updates beyond 1.1.0 until a fixed version is released.
      matchManagers: ["bazel-module"],
      matchPackageNames: ["score_tooling"],
      allowedVersions: "<=1.1.0",
    }
  ],
}
